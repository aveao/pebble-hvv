      "FAV_2",
      "FAV_3",
      "FAV_4",
      "FAV_5",
      "CONFIG_MAX_NEARBY",
      "CONFIG_MAX_DEPARTURES"
    ],
    "projectRepositoryUrl": "https://github.com/aveao/pebble-hvv",
    "screenshots": [
      ".assets/basalt_screenshot_mainpage.png",
      ".assets/basalt_screenshot_hbf.png",
      ".assets/basalt_screenshot_berliner_tor.png",
      ".assets/emery_screenshot_mainpage.png",
      ".assets/emery_screenshot_jungfernstieg.png"
    ],
    "resources": {
      "media": [
        {
          "type": "png",
